# Copy this to terraform.tfvars and fill in real values.
# DO NOT commit terraform.tfvars (it's in .gitignore).

# Existing EC2 key pair name in ap-south-1.
# Create one in the AWS Console first (EC2 → Key Pairs → Create) and download
# the .pem to ~/.ssh/. Then put the NAME here (no .pem extension).
key_pair_name = "nira-aws"

# SSH source range.
#   - Tight (recommended for prod): your laptop IP, e.g. "203.0.113.42/32".
#     Find it with:  curl -s https://ipv4.icanhazip.com
#   - Open (OK for dev — relies on key-only auth + fail2ban):  "0.0.0.0/0"
#     SSH is key-only on the EC2 (passwords disabled) and fail2ban bans
#     brute-forcers, so this is reasonable for low-stakes dev/staging.
ssh_allowed_cidr = "0.0.0.0/0"

# Public HTTPS URL of your repo. Must be readable WITHOUT auth (public repo)
# OR you'll need to set up a deploy key on the EC2 first.
repo_url = "https://github.com/breathe-again/nira-insog"

# Optional overrides — defaults are fine for v0.
# aws_region    = "ap-south-1"
# instance_type = "t3.small"
# root_disk_gb  = 20
# repo_branch   = "main"
