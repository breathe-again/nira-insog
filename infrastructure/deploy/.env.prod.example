# Copy this to .env.prod on the EC2 box and fill in real values.
# Do NOT commit .env.prod.

# Public domain pointing at the EC2's elastic IP (set up in Cloudflare).
PUBLIC_HOST=insig.nirabalance.com

# Email for Let's Encrypt certificate notifications.
ACME_EMAIL=koustav@nirabalance.com

# App env — turn ON the strict prod safety checks. The API REFUSES to boot
# in this mode if any of JWT_SECRET / COOKIE_SECURE / FILE_ENCRYPTION_KEY
# are at unsafe defaults. See backend/api/config.py validate_for_prod().
APP_ENV=prod

# ---------- Auth / security ----------
# Generate a long random secret:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=REPLACE-ME-WITH-A-64-CHAR-RANDOM-STRING
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.nirabalance.com   # only set if you serve multiple subdomains

# Local-dev only — NEVER set in prod. The API refuses to boot when both
# APP_ENV=prod and DEMO_MODE=true.
DEMO_MODE=false

# ---------- File encryption at rest ----------
# Generate a Fernet key (urlsafe base64 of 32 bytes):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Uploaded documents are encrypted with this key on disk. Lose the key,
# lose the ability to decrypt existing uploads — back it up to a secure store.
FILE_ENCRYPTION_KEY=REPLACE-ME

# ---------- Database ----------
# Neon connection string.
#
# For low-traffic v0, use the DIRECT endpoint (NOT -pooler) — PgBouncer in
# transaction-pooling mode breaks Alembic migrations and some psycopg
# operations. Direct gives you up to ~100 connections, plenty for v0.
#
# Get it from Neon dashboard → Connection details → toggle OFF "Pooled connection".
# MUST include sslmode=require.
#
# When you scale beyond ~50 simultaneous users, switch to -pooler and run
# migrations separately via the direct endpoint.
DATABASE_URL=postgresql+psycopg://USER:PASS@ep-xxxxx.ap-south-1.aws.neon.tech/nira_insig?sslmode=require

# ---------- Redis ----------
# Redis runs in docker on the same box, or use Upstash with rediss:// + ssl_cert_reqs.
REDIS_URL=redis://redis:6379/0

# ---------- CORS ----------
# Must include the https origin the browser will use. NEVER set to "*" in prod
# (the API refuses to boot — CORS spec doesn't allow "*" with credentialed cookies).
CORS_ORIGINS=https://insig.nirabalance.com

# ---------- Extraction ----------
# Anthropic vision API key — required for PDF/image/HTML/XLSX extraction.
ANTHROPIC_API_KEY=
