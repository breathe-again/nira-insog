# Copy this to .env.prod on the EC2 box and fill in real values.
# Do NOT commit .env.prod.

# Public domain pointing at the EC2's elastic IP (set up in Cloudflare).
PUBLIC_HOST=insig.nirabalance.com

# Email for Let's Encrypt certificate notifications.
ACME_EMAIL=koustav@nirabalance.com

# Neon connection string.
#
# For low-traffic v0, use the DIRECT endpoint (NOT -pooler) — PgBouncer in
# transaction-pooling mode breaks Alembic migrations and some psycopg
# operations. Direct gives you up to ~100 connections, plenty for v0.
#
# Get it from Neon dashboard → Connection details → toggle OFF "Pooled connection".
# MUST include sslmode=require.
#
# When you scale beyond ~50 simultaneous users, switch to -pooler and run
# migrations separately via the direct endpoint.
DATABASE_URL=postgresql+psycopg://USER:PASS@ep-xxxxx.ap-south-1.aws.neon.tech/nira_insig?sslmode=require

# Redis runs in docker on the same box.
REDIS_URL=redis://redis:6379/0

# CORS — must include the https origin the browser will use.
CORS_ORIGINS=https://insig.nirabalance.com

# Optional: leave blank until OCR/LLM extraction is wired.
ANTHROPIC_API_KEY=
