# Copy to .env if you want to override defaults locally.
# Docker compose reads the variables below into the api service.

# --- Backend ---
APP_ENV=dev
LOG_LEVEL=INFO

# Used by the api container; in docker compose these point at the postgres / redis services.
# Override only if you are running the api outside docker.
DATABASE_URL=postgresql+psycopg://nira:nira@postgres:5432/nira_insig
REDIS_URL=redis://redis:6379/0

# CORS — comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- LLM extractor ---
# Anthropic API key. When set, the worker sends uploaded PDFs / images to
# Claude (vision) and extracts structured invoice / receipt / statement JSON.
# When unset, the worker falls back to the stub payload (system still runs).
# Get one at https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# --- Frontend ---
# Where the browser should hit the API. Read by Vite at build/dev time.
VITE_API_BASE=http://localhost:8000
